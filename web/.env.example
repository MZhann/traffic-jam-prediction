NEXT_PUBLIC_API_URL=http://localhost:4000

# Map provider — set ONE of the keys below. Yandex takes priority over 2GIS.
# When neither is set, the map falls back to Leaflet + CartoDB Voyager tiles
# (no key needed, looks decent).

# Yandex Maps JS API v3 key — free tier at https://developer.tech.yandex.ru/services/
# Pick the "JavaScript API and HTTP Geocoder" service.
NEXT_PUBLIC_YANDEX_MAPS_KEY=

# 2GIS MapGL key — free tier at https://platform.2gis.com/
NEXT_PUBLIC_MAPGL_KEY=
